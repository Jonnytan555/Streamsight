# ── API Keys ─────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to true to skip Claude/Perplexity entirely.
# Articles will be queued and written but summaries will be the raw body text.
# Useful for testing the pipeline without API keys.
DEMO_MODE=false

# ── Database (optional — only needed if not using Windows auth on localhost) ──
# Uncomment for Docker (containers can't use Windows auth):
#DB_SERVER=host.docker.internal
#DB_USER=streamsight
#DB_PASS=Stream$ight1!

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
