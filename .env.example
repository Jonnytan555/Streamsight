# ── Database ─────────────────────────────────────────────────────────────────
# Both local runners and the server API must point to the same SQL Server instance.
DB_SERVER=your-sql-server-host
DB_NAME=STREAMSIGHT
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_USER=
DB_PASS=

# ── API Keys (runners only — not needed on the server) ───────────────────────
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=
