# ── Environment ────────────────────────────────────────────────────────────────
# Set SERVER=PRD to enable real Ping authentication.
# In DEV all requests are treated as a fake "Dev User" — no Ping needed.
SERVER=DEV

# ── Ping OAuth ──────────────────────────────────────────────────────────────────
# Ask your Ping admin for these four values and register your redirect URI.

# The base URL of your Ping server — no trailing slash.
# PingFederate example:  https://sso.yourcompany.com
# PingOne example:       https://auth.pingone.com/YOUR_ENV_ID/as
PING_ISSUER=

# The OAuth client registered in Ping for this application.
PING_CLIENT_ID=
PING_CLIENT_SECRET=

# Must exactly match what is registered in Ping under the client's redirect URIs.
# DEV:  http://localhost:5173/auth/callback
# PRD:  https://yourapp.com/auth/callback
PING_REDIRECT_URI=http://localhost:5173/auth/callback

# Scopes to request — openid is required, profile and email give you name/email.
PING_SCOPE=openid profile email

# Override these only if your Ping instance uses non-standard endpoint paths.
# Defaults are PingFederate paths — leave blank for default.
# PING_AUTHORIZE_URL=
# PING_TOKEN_URL=
# PING_JWKS_URL=

# ── App ─────────────────────────────────────────────────────────────────────────
# After login Ping redirects here — should be your React app's root URL.
# DEV:  http://localhost:5173
# PRD:  https://yourapp.com
APP_BASE_URL=http://localhost:5173

SESSION_COOKIE_NAME=cnt_session
